{
  "name": "attendx",
  "version": "1.0.0",
  "description": "Attendance Register App",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.attendx.app",
    "productName": "AttendX",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.cjs"
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
